{#
/**
 * @file
 * page.html.twig — régions du thème.
 */
#}
{% set live_feed_path = path('entity.node.canonical', {'node': 4}) %}
{% set login_path = path('user.login') %}
{% set current_route = app.request.attributes.get('_route') %}
{% set is_article_add = current_route == 'node.add' and app.request.attributes.get('node_type') == 'article' %}
<header class="site-header" role="banner">
  <div class="layout-container site-header__inner">
    <div class="site-header__brand">
      <a href="{{ path('<front>') }}" class="site-header__logo" aria-label="{{ 'Accueil ELCA Blog'|t }}">
        <img src="/themes/custom/drivepress/css/assets/ELCA_Informatik_logo.svg" alt="{{ 'ELCA'|t }}" class="site-header__logo-img">
      </a>
    </div>
    <input type="checkbox" id="site-header-nav-toggle" class="site-header__nav-toggle">
    <label for="site-header-nav-toggle" class="site-header__burger" aria-label="{{ 'Ouvrir ou fermer le menu'|t }}">
      <span class="site-header__burger-bar" aria-hidden="true"></span>
      <span class="site-header__burger-bar" aria-hidden="true"></span>
      <span class="site-header__burger-bar" aria-hidden="true"></span>
    </label>
    <nav class="site-header__nav" aria-label="{{ 'Navigation principale'|t }}">
      <ul class="site-header__menu">
        <li class="site-header__item">
          <a href="{{ path('<front>') }}" class="site-header__link{{ is_front ? ' is-active' : '' }}">{{ 'Accueil'|t }}</a>
        </li>
        <li class="site-header__item">
          <a href="{{ live_feed_path }}" class="site-header__link{{ app.request.pathinfo == live_feed_path ? ' is-active' : '' }}">{{ 'Fil en direct'|t }}</a>
        </li>
        {% if logged_in %}
          {% if user.hasPermission('create article content') %}
            <li class="site-header__item">
              <a href="{{ path('node.add', {'node_type': 'article'}) }}" class="site-header__link">{{ 'Ajouter un article'|t }}</a>
            </li>
            <li class="site-header__item">
              <a href="/mes-articles" class="site-header__link">{{ 'Mes articles'|t }}</a>
            </li>
          {% endif %}
          <li class="site-header__item">
            <a href="{{ path('entity.user.canonical', {'user': user.id}) }}" class="site-header__link">{{ 'Mon compte'|t }}</a>
          </li>
          <li class="site-header__item">
            <a href="{{ path('user.logout') }}" class="site-header__link site-header__link--cta">{{ 'Se déconnecter'|t }}</a>
          </li>
        {% else %}
          <li class="site-header__item">
            <a href="{{ login_path }}" class="site-header__link site-header__link--cta{{ app.request.pathinfo == login_path ? ' is-active' : '' }}">{{ 'Se connecter'|t }}</a>
          </li>
        {% endif %}
      </ul>
    </nav>
  </div>
</header>

{% if is_front or app.request.pathinfo == live_feed_path %}
  <div class="hero">
    <div class="layout-container">
      <h1>ELCA Blog</h1>
      <p>Développement web, innovation digitale et bonnes pratiques</p>
    </div>
  </div>
{% endif %}

<main class="layout-container">
  <div class="articles-grid{{ is_article_add ? ' article-add-page' : '' }}">
    {% if page.content %}
      {% if current_route == 'user.login' %}
        <div class="auth-shell">
          <img src="/themes/custom/drivepress/css/assets/ELCA_Informatik_logo.svg" alt="{{ 'ELCA'|t }}" class="auth-shell__logo">
          <p class="auth-shell__subtitle">{{ 'Connexion à votre espace ELCA Blog'|t }}</p>
          {{ page.content }}
        </div>
      {% else %}
        {{ page.content }}
      {% endif %}
    {% endif %}
  </div>
</main>

<footer>
  <div class="layout-container">
    <p>&copy; {{ "now"|date("Y") }} ELCA Blog — Développement web & innovation digitale</p>
  </div>
</footer>
